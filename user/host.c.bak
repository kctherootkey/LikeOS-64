/*
 * host - DNS lookup utility
 *
 * Usage: host [-t type] [-v] name [server]
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <netdb.h>
#include <arpa/inet.h>

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

int main(int argc, char *argv[])
{
    int verbose = 0;
    const char *name = NULL;
    int i;

    for (i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-h") == 0 || strcmp(argv[i], "--help") == 0) {
            printf("Usage: host [-t type] [-v] [-4] [-6] name [server]\n");
            printf("DNS lookup utility.\n\n");
            printf("Options:\n");
            printf("  -t type    specify query type (A, AAAA, MX, NS, etc.)\n");
            printf("  -v         verbose output\n");
            printf("  -4         use IPv4 query transport only\n");
            printf("  -6         use IPv6 query transport only\n");
            printf("  -a         equivalent to -v -t ANY\n");
            return 0;
        }
        if (strcmp(argv[i], "-v") == 0) { verbose = 1; continue; }
        if (strcmp(argv[i], "-t") == 0) { i++; continue; } /* skip type */
        if (strcmp(argv[i], "-4") == 0 || strcmp(argv[i], "-6") == 0) continue;
        if (strcmp(argv[i], "-a") == 0) { verbose = 1; continue; }
        if (!name) name = argv[i];
    }

    if (!name) {
        fprintf(stderr, "Usage: host [-t type] [-v] name [server]\n");
        return 1;
    }

    uint32_t ip;
    int ret = dns_resolve(name, &ip);

    if (ret == 0) {
        if (verbose) {
            printf("Trying \"%s\"\n", name);
            printf(";; ->>HEADER<<- opcode: QUERY, status: NOERROR, id: 1\n");
            printf(";; ANSWER SECTION:\n");
            printf("%s.\t\t300\tIN\tA\t%s\n\n", name, ip_str(ip));
        } else {
            printf("%s has address %s\n", name, ip_str(ip));
        }
    } else {
        printf("Host %s not found: 3(NXDOMAIN)\n", name);
        return 1;
    }

    return 0;
}
