/*
 * ping - send ICMP ECHO_REQUEST to network hosts
 *
 * Usage: ping [-c count] [-i interval] [-s packetsize] [-t ttl] [-w deadline]
 *             [-W timeout] [-q] [-v] destination
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <getopt.h>
#include <netdb.h>
#include <arpa/inet.h>

static void print_help(const char *progname)
{
    printf("Usage: %s [OPTIONS] destination\n", progname);
    printf("Send ICMP ECHO_REQUEST to network hosts.\n\n");
    printf("Options:\n");
    printf("  -c count       stop after sending count packets\n");
    printf("  -i interval    seconds between sending each packet (default 1)\n");
    printf("  -s packetsize  size of data bytes to send (default 56)\n");
    printf("  -t ttl         set Time To Live\n");
    printf("  -w deadline    timeout in seconds for the entire ping\n");
    printf("  -W timeout     time to wait for a response, in seconds (default 5)\n");
    printf("  -q             quiet output\n");
    printf("  -v             verbose output\n");
    printf("  -h             display this help and exit\n");
}

static uint32_t resolve_host(const char *host)
{
    /* Try as dotted IP first */
    uint32_t ip = inet_addr(host);
    if (ip != 0 && ip != 0xFFFFFFFF) {
        /* inet_addr returns network byte order, convert to host */
        return ntohl(ip);
    }
    /* DNS resolve */
    uint32_t resolved;
    if (dns_resolve(host, &resolved) == 0)
        return resolved;
    return 0;
}

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

int main(int argc, char *argv[])
{
    int count = -1;    /* -1 = infinite */
    int interval = 1;
    int ttl = 64;
    int deadline = 0;
    int timeout = 5;
    int quiet = 0;
    int verbose = 0;
    int opt;

    while ((opt = getopt(argc, argv, "c:i:s:t:w:W:qvh")) != -1) {
        switch (opt) {
            case 'c': count = atoi(optarg); break;
            case 'i': interval = atoi(optarg); break;
            case 's': /* packetsize - accepted but not used (kernel uses 56) */ break;
            case 't': ttl = atoi(optarg); break;
            case 'w': deadline = atoi(optarg); break;
            case 'W': timeout = atoi(optarg); break;
            case 'q': quiet = 1; break;
            case 'v': verbose = 1; break;
            case 'h': print_help(argv[0]); return 0;
            default: print_help(argv[0]); return 1;
        }
    }

    if (optind >= argc) {
        fprintf(stderr, "ping: usage error: Destination address required\n");
        return 1;
    }

    const char *dest = argv[optind];
    uint32_t dst_ip = resolve_host(dest);
    if (dst_ip == 0) {
        fprintf(stderr, "ping: %s: Name or service not known\n", dest);
        return 1;
    }

    printf("PING %s (%s) 56(84) bytes of data.\n", dest, ip_str(dst_ip));

    uint16_t id = (uint16_t)(getpid() & 0xFFFF);
    int sent = 0, received = 0;
    uint32_t min_ms = 0xFFFFFFFF, max_ms = 0, total_ms = 0;
    uint64_t deadline_ticks = 0;

    if (deadline > 0)
        deadline_ticks = (uint64_t)deadline * 100; /* 100Hz tick */

    for (int seq = 1; count < 0 || seq <= count; seq++) {
        /* Check deadline */
        if (deadline > 0 && deadline_ticks == 0)
            break;

        /* Send ICMP echo */
        uint32_t id_seq = ((uint32_t)id << 16) | (uint16_t)seq;
        int ret = raw_send(RAW_SEND_ICMP_ECHO, dst_ip, id_seq, (uint32_t)ttl);
        if (ret < 0) {
            if (!quiet)
                fprintf(stderr, "ping: sendto: Network is unreachable\n");
            sent++;
            if (interval > 0) sleep((unsigned)interval);
            continue;
        }
        sent++;

        /* Wait for reply */
        uint64_t timeout_ticks = (uint64_t)timeout * 100;
        uint8_t result[8];
        ret = raw_recv(RAW_RECV_ICMP_REPLY, result, id, timeout_ticks);
        if (ret == 0) {
            received++;
            uint32_t src = ((uint32_t)result[0] << 24) | ((uint32_t)result[1] << 16) |
                           ((uint32_t)result[2] << 8) | result[3];
            uint8_t type = result[4];
            uint16_t rseq = ((uint16_t)result[6] << 8) | result[7];

            /* Approximate RTT - we don't have precise timing, estimate ~1ms */
            uint32_t rtt_ms = 1;
            if (min_ms > rtt_ms) min_ms = rtt_ms;
            if (max_ms < rtt_ms) max_ms = rtt_ms;
            total_ms += rtt_ms;

            if (!quiet) {
                if (type == 0) {
                    printf("64 bytes from %s: icmp_seq=%u ttl=%d time=%u ms\n",
                           ip_str(src), rseq, ttl, rtt_ms);
                } else if (type == 11) {
                    printf("From %s icmp_seq=%u Time to live exceeded\n",
                           ip_str(src), rseq);
                }
            }
        } else {
            if (!quiet && verbose)
                printf("Request timeout for icmp_seq %d\n", seq);
        }

        if (count < 0 || seq < count) {
            if (interval > 0) sleep((unsigned)interval);
        }
    }

    /* Statistics */
    int loss = sent > 0 ? ((sent - received) * 100 / sent) : 0;
    printf("\n--- %s ping statistics ---\n", dest);
    printf("%d packets transmitted, %d received, %d%% packet loss\n",
           sent, received, loss);
    if (received > 0) {
        uint32_t avg_ms = total_ms / (uint32_t)received;
        printf("rtt min/avg/max = %u/%u/%u ms\n", min_ms, avg_ms, max_ms);
    }

    return received > 0 ? 0 : 1;
}
