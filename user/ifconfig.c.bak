/*
 * ifconfig - configure a network interface
 *
 * Usage: ifconfig [interface] [options]
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/socket.h>
#include <sys/ioctl.h>
#include <net/if.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <netdb.h>

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

static void print_flags(uint16_t flags)
{
    printf("<");
    int first = 1;
    #define PF(f, s) if (flags & f) { if (!first) printf(","); printf(s); first = 0; }
    PF(IFF_UP, "UP");
    PF(IFF_BROADCAST, "BROADCAST");
    PF(IFF_LOOPBACK, "LOOPBACK");
    PF(IFF_RUNNING, "RUNNING");
    PF(IFF_NOARP, "NOARP");
    PF(IFF_PROMISC, "PROMISC");
    PF(IFF_MULTICAST, "MULTICAST");
    PF(IFF_ALLMULTI, "ALLMULTI");
    #undef PF
    printf(">");
}

static void show_interface(const net_iface_info_t *iface)
{
    printf("%s: flags=%u ", iface->name, iface->flags);
    print_flags(iface->flags);
    printf("  mtu %u\n", iface->mtu);

    if (iface->ip != 0 || strcmp(iface->name, "lo") == 0) {
        printf("        inet %s", ip_str(iface->ip));
        printf("  netmask %s", ip_str(iface->netmask));
        if (iface->broadcast != 0 && !(iface->flags & IFF_LOOPBACK))
            printf("  broadcast %s", ip_str(iface->broadcast));
        printf("\n");
    }

    if (!(iface->flags & IFF_LOOPBACK)) {
        printf("        ether %02x:%02x:%02x:%02x:%02x:%02x",
               iface->mac[0], iface->mac[1], iface->mac[2],
               iface->mac[3], iface->mac[4], iface->mac[5]);
        printf("  txqueuelen 1000\n");
    }

    printf("        RX packets %lu  bytes %lu\n",
           (unsigned long)iface->rx_packets, (unsigned long)iface->rx_bytes);
    printf("        TX packets %lu  bytes %lu\n",
           (unsigned long)iface->tx_packets, (unsigned long)iface->tx_bytes);
    printf("\n");
}

static void show_all_interfaces(int all)
{
    net_iface_info_t ifaces[8];
    int n = net_getinfo(NET_GET_IFACE_INFO, ifaces, 8);
    for (int i = 0; i < n; i++) {
        if (!all && !(ifaces[i].flags & IFF_UP))
            continue;
        show_interface(&ifaces[i]);
    }
}

static void show_one_interface(const char *name)
{
    net_iface_info_t ifaces[8];
    int n = net_getinfo(NET_GET_IFACE_INFO, ifaces, 8);
    for (int i = 0; i < n; i++) {
        if (strcmp(ifaces[i].name, name) == 0) {
            show_interface(&ifaces[i]);
            return;
        }
    }
    fprintf(stderr, "ifconfig: interface %s does not exist\n", name);
}

static int set_addr(int fd, const char *ifname, unsigned long req, const char *addr_str)
{
    struct ifreq ifr;
    memset(&ifr, 0, sizeof(ifr));
    strncpy(ifr.ifr_name, ifname, IFNAMSIZ - 1);

    struct sockaddr_in *sin = (struct sockaddr_in *)&ifr.ifr_addr;
    sin->sin_family = AF_INET;
    sin->sin_addr.s_addr = inet_addr(addr_str);

    return ioctl(fd, req, &ifr);
}

static int set_flags(int fd, const char *ifname, short flags, int set)
{
    struct ifreq ifr;
    memset(&ifr, 0, sizeof(ifr));
    strncpy(ifr.ifr_name, ifname, IFNAMSIZ - 1);

    if (ioctl(fd, SIOCGIFFLAGS, &ifr) < 0) return -1;

    if (set)
        ifr.ifr_flags |= flags;
    else
        ifr.ifr_flags &= ~flags;

    return ioctl(fd, SIOCSIFFLAGS, &ifr);
}

static void print_help(void)
{
    printf("Usage: ifconfig [-a] [interface]\n");
    printf("       ifconfig interface [address] [netmask MASK] [broadcast BCAST]\n");
    printf("       ifconfig interface up|down\n");
    printf("       ifconfig interface mtu N\n");
    printf("       ifconfig interface hw ether XX:XX:XX:XX:XX:XX\n");
}

int main(int argc, char *argv[])
{
    if (argc == 1) {
        show_all_interfaces(0);
        return 0;
    }

    if (strcmp(argv[1], "-a") == 0) {
        show_all_interfaces(1);
        return 0;
    }

    if (strcmp(argv[1], "--help") == 0 || strcmp(argv[1], "-h") == 0) {
        print_help();
        return 0;
    }

    const char *ifname = argv[1];

    if (argc == 2) {
        show_one_interface(ifname);
        return 0;
    }

    /* Configuration mode */
    int fd = socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) {
        fprintf(stderr, "ifconfig: socket: Cannot create socket\n");
        return 1;
    }

    int i = 2;
    while (i < argc) {
        if (strcmp(argv[i], "up") == 0) {
            set_flags(fd, ifname, IFF_UP | IFF_RUNNING, 1);
            i++;
        } else if (strcmp(argv[i], "down") == 0) {
            set_flags(fd, ifname, IFF_UP | IFF_RUNNING, 0);
            i++;
        } else if (strcmp(argv[i], "netmask") == 0 && i + 1 < argc) {
            set_addr(fd, ifname, SIOCSIFNETMASK, argv[i + 1]);
            i += 2;
        } else if (strcmp(argv[i], "broadcast") == 0 && i + 1 < argc) {
            set_addr(fd, ifname, SIOCSIFBRDADDR, argv[i + 1]);
            i += 2;
        } else if (strcmp(argv[i], "mtu") == 0 && i + 1 < argc) {
            struct ifreq ifr;
            memset(&ifr, 0, sizeof(ifr));
            strncpy(ifr.ifr_name, ifname, IFNAMSIZ - 1);
            ifr.ifr_mtu = atoi(argv[i + 1]);
            ioctl(fd, SIOCSIFMTU, &ifr);
            i += 2;
        } else if (strcmp(argv[i], "hw") == 0 && i + 2 < argc && strcmp(argv[i+1], "ether") == 0) {
            struct ifreq ifr;
            memset(&ifr, 0, sizeof(ifr));
            strncpy(ifr.ifr_name, ifname, IFNAMSIZ - 1);
            unsigned int mac[6];
            if (sscanf(argv[i + 2], "%x:%x:%x:%x:%x:%x",
                       &mac[0], &mac[1], &mac[2], &mac[3], &mac[4], &mac[5]) == 6) {
                ifr.ifr_hwaddr.sa_family = 1; /* ARPHRD_ETHER */
                for (int j = 0; j < 6; j++)
                    ifr.ifr_hwaddr.sa_data[j] = (char)mac[j];
                ioctl(fd, SIOCSIFHWADDR, &ifr);
            }
            i += 3;
        } else {
            /* Assume it's an IP address */
            set_addr(fd, ifname, SIOCSIFADDR, argv[i]);
            i++;
        }
    }

    close(fd);
    return 0;
}
