/*
 * arp - manipulate the system ARP cache
 *
 * Usage: arp [-a] [-n] [-d address] [-s address hw_addr]
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/socket.h>
#include <sys/ioctl.h>
#include <net/if.h>
#include <net/route.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <netdb.h>

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

static void show_arp_table(int numeric)
{
    (void)numeric;
    net_arp_info_t entries[64];
    int n = net_getinfo(NET_GET_ARP_TABLE, entries, 64);

    printf("Address                  HWtype  HWaddress           Flags  Iface\n");

    for (int i = 0; i < n; i++) {
        printf("%-24s ether   %02x:%02x:%02x:%02x:%02x:%02x   C      %s\n",
               ip_str(entries[i].ip),
               entries[i].mac[0], entries[i].mac[1], entries[i].mac[2],
               entries[i].mac[3], entries[i].mac[4], entries[i].mac[5],
               entries[i].device);
    }

    if (n == 0)
        printf("(no ARP entries)\n");
}

static int delete_entry(const char *addr)
{
    int fd = socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) return -1;

    struct arpreq req;
    memset(&req, 0, sizeof(req));

    struct sockaddr_in *sin = (struct sockaddr_in *)&req.arp_pa;
    sin->sin_family = AF_INET;
    sin->sin_addr.s_addr = inet_addr(addr);

    int ret = ioctl(fd, SIOCDARP, &req);
    close(fd);
    return ret;
}

static int set_entry(const char *addr, const char *mac_str)
{
    int fd = socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) return -1;

    struct arpreq req;
    memset(&req, 0, sizeof(req));

    struct sockaddr_in *sin = (struct sockaddr_in *)&req.arp_pa;
    sin->sin_family = AF_INET;
    sin->sin_addr.s_addr = inet_addr(addr);

    unsigned int mac[6];
    if (sscanf(mac_str, "%x:%x:%x:%x:%x:%x",
               &mac[0], &mac[1], &mac[2], &mac[3], &mac[4], &mac[5]) != 6) {
        fprintf(stderr, "arp: invalid hardware address: %s\n", mac_str);
        close(fd);
        return -1;
    }

    req.arp_ha.sa_family = 1; /* ARPHRD_ETHER */
    for (int i = 0; i < 6; i++)
        req.arp_ha.sa_data[i] = (char)mac[i];
    req.arp_flags = ATF_COM | ATF_PERM;

    int ret = ioctl(fd, SIOCSARP, &req);
    close(fd);
    return ret;
}

static void print_help(void)
{
    printf("Usage: arp [-a] [-n] [-d address] [-s address hw_addr] [-i interface]\n");
    printf("\nOptions:\n");
    printf("  -a             display all entries (default)\n");
    printf("  -n             show numerical addresses\n");
    printf("  -d address     delete an ARP entry\n");
    printf("  -s address hw  create an ARP entry\n");
    printf("  -i interface   select an interface\n");
    printf("  -v             be verbose\n");
}

int main(int argc, char *argv[])
{
    int numeric = 0;
    int opt;

    while ((opt = getopt(argc, argv, "and:s:i:vh")) != -1) {
        switch (opt) {
            case 'a': break;
            case 'n': numeric = 1; break;
            case 'd':
                if (delete_entry(optarg) < 0) {
                    fprintf(stderr, "arp: SIOCDARP: No such entry\n");
                    return 1;
                }
                return 0;
            case 's':
                if (optind < argc) {
                    if (set_entry(optarg, argv[optind]) < 0) {
                        fprintf(stderr, "arp: SIOCSARP: Operation failed\n");
                        return 1;
                    }
                    return 0;
                }
                fprintf(stderr, "arp: need hardware address\n");
                return 1;
            case 'i': /* interface filter - not implemented */ break;
            case 'v': break;
            case 'h': print_help(); return 0;
            default: print_help(); return 1;
        }
    }

    show_arp_table(numeric);
    return 0;
}
