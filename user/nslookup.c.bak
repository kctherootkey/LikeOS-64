/*
 * nslookup - query Internet name servers interactively
 *
 * Usage: nslookup [name] [server]
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <netdb.h>
#include <arpa/inet.h>

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

static int lookup(const char *name)
{
    uint32_t ip;
    int ret = dns_resolve(name, &ip);

    printf("Server:\t\t(system DNS)\n");
    printf("Address:\t(system DNS)\n\n");

    if (ret == 0) {
        printf("Non-authoritative answer:\n");
        printf("Name:\t%s\n", name);
        printf("Address: %s\n\n", ip_str(ip));
    } else {
        printf("** server can't find %s: NXDOMAIN\n\n", name);
    }

    return ret == 0 ? 0 : 1;
}

int main(int argc, char *argv[])
{
    if (argc < 2 || strcmp(argv[1], "-h") == 0 || strcmp(argv[1], "--help") == 0) {
        printf("Usage: nslookup [name] [server]\n");
        printf("Query Internet name servers.\n\n");
        printf("  name      domain name to look up\n");
        printf("  server    DNS server to query (ignored, uses system DNS)\n");
        printf("\nOptions:\n");
        printf("  -type=TYPE    set query type (A, AAAA, MX, etc.)\n");
        printf("  -h            display this help and exit\n");
        return argc < 2 ? 1 : 0;
    }

    /* Skip -type= options */
    const char *name = NULL;
    for (int i = 1; i < argc; i++) {
        if (argv[i][0] != '-') {
            if (!name) name = argv[i];
            /* else server - ignored */
        }
    }

    if (!name) {
        fprintf(stderr, "nslookup: no name specified\n");
        return 1;
    }

    return lookup(name);
}
