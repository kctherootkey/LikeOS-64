/*
 * netstat - print network connections, routing tables, interface statistics
 *
 * Usage: netstat [OPTIONS]
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <getopt.h>
#include <netdb.h>
#include <arpa/inet.h>

static const char *tcp_state_str(int state)
{
    switch (state) {
        case 0: return "CLOSED";
        case 1: return "LISTEN";
        case 2: return "SYN_SENT";
        case 3: return "SYN_RECV";
        case 4: return "ESTABLISHED";
        case 5: return "FIN_WAIT1";
        case 6: return "FIN_WAIT2";
        case 7: return "CLOSE_WAIT";
        case 8: return "CLOSING";
        case 9: return "LAST_ACK";
        case 10: return "TIME_WAIT";
        default: return "UNKNOWN";
    }
}

static const char *ip_str(uint32_t ip)
{
    struct in_addr a;
    a.s_addr = htonl(ip);
    return inet_ntoa(a);
}

static void show_tcp(int listening_only, int numeric)
{
    (void)numeric;
    net_tcp_info_t conns[64];
    int n = net_getinfo(NET_GET_TCP_CONNS, conns, 64);
    if (n <= 0) return;

    printf("Active Internet connections\n");
    printf("Proto Recv-Q Send-Q %-23s %-23s State\n", "Local Address", "Foreign Address");

    for (int i = 0; i < n; i++) {
        if (listening_only && conns[i].state != 1)
            continue;

        char local[32], remote[32];
        snprintf(local, sizeof(local), "%s:%u", ip_str(conns[i].local_addr), conns[i].local_port);
        snprintf(remote, sizeof(remote), "%s:%u", ip_str(conns[i].remote_addr), conns[i].remote_port);

        printf("tcp        0      0 %-23s %-23s %s\n",
               local, remote, tcp_state_str(conns[i].state));
    }
}

static void show_udp(int numeric)
{
    (void)numeric;
    net_udp_info_t socks[64];
    int n = net_getinfo(NET_GET_UDP_SOCKS, socks, 64);
    if (n <= 0) return;

    printf("Proto Recv-Q Send-Q %-23s %-23s State\n", "Local Address", "Foreign Address");

    for (int i = 0; i < n; i++) {
        char local[32];
        snprintf(local, sizeof(local), "%s:%u", ip_str(socks[i].local_addr), socks[i].local_port);
        printf("udp        0      0 %-23s %-23s\n", local, "0.0.0.0:*");
    }
}

static void show_route(void)
{
    net_route_info_t routes[32];
    int n = net_getinfo(NET_GET_ROUTE_TABLE, routes, 32);

    printf("Kernel IP routing table\n");
    printf("%-16s %-16s %-16s Flags %-6s Iface\n",
           "Destination", "Gateway", "Genmask", "Metric");

    for (int i = 0; i < n; i++) {
        char flags[8] = "U";
        int fi = 1;
        if (routes[i].flags & 0x0002) flags[fi++] = 'G';
        if (routes[i].flags & 0x0004) flags[fi++] = 'H';
        flags[fi] = '\0';

        printf("%-16s %-16s %-16s %-5s %-6d %s\n",
               ip_str(routes[i].dest),
               ip_str(routes[i].gateway),
               ip_str(routes[i].netmask),
               flags, 0, routes[i].device);
    }
}

static void show_interfaces(void)
{
    net_iface_info_t ifaces[8];
    int n = net_getinfo(NET_GET_IFACE_INFO, ifaces, 8);

    printf("Kernel Interface table\n");
    printf("%-10s %-5s %-16s RX-OK  RX-Bytes  TX-OK  TX-Bytes  Flg\n",
           "Iface", "MTU", "Address");

    for (int i = 0; i < n; i++) {
        printf("%-10s %-5u %-16s %-6lu %-9lu %-6lu %-9lu ",
               ifaces[i].name, ifaces[i].mtu, ip_str(ifaces[i].ip),
               (unsigned long)ifaces[i].rx_packets, (unsigned long)ifaces[i].rx_bytes,
               (unsigned long)ifaces[i].tx_packets, (unsigned long)ifaces[i].tx_bytes);
        if (ifaces[i].flags & 0x0040) printf("R");
        if (ifaces[i].flags & 0x0001) printf("U");
        if (ifaces[i].flags & 0x0008) printf("L");
        printf("\n");
    }
}

static void print_help(const char *progname)
{
    printf("Usage: %s [OPTIONS]\n", progname);
    printf("Print network connections, routing tables, interface statistics.\n\n");
    printf("Options:\n");
    printf("  -a, --all            show both listening and non-listening sockets\n");
    printf("  -t, --tcp            show TCP connections\n");
    printf("  -u, --udp            show UDP connections\n");
    printf("  -l, --listening      show only listening sockets\n");
    printf("  -n, --numeric        show numerical addresses\n");
    printf("  -r, --route          display routing table\n");
    printf("  -i, --interfaces     display interface table\n");
    printf("  -p, --program        show PID/program name\n");
    printf("  -s, --statistics     display networking statistics\n");
    printf("  -h, --help           display this help and exit\n");
}

int main(int argc, char *argv[])
{
    static struct option long_options[] = {
        {"all",        no_argument, 0, 'a'},
        {"tcp",        no_argument, 0, 't'},
        {"udp",        no_argument, 0, 'u'},
        {"listening",  no_argument, 0, 'l'},
        {"numeric",    no_argument, 0, 'n'},
        {"route",      no_argument, 0, 'r'},
        {"interfaces", no_argument, 0, 'i'},
        {"program",    no_argument, 0, 'p'},
        {"statistics", no_argument, 0, 's'},
        {"help",       no_argument, 0, 'h'},
        {0, 0, 0, 0}
    };

    int show_tcp_flag = 0, show_udp_flag = 0, show_route_flag = 0;
    int show_ifaces = 0, listening = 0, numeric = 0;
    int opt;

    while ((opt = getopt_long(argc, argv, "atulnripsh", long_options, NULL)) != -1) {
        switch (opt) {
            case 'a': show_tcp_flag = 1; show_udp_flag = 1; break;
            case 't': show_tcp_flag = 1; break;
            case 'u': show_udp_flag = 1; break;
            case 'l': listening = 1; break;
            case 'n': numeric = 1; break;
            case 'r': show_route_flag = 1; break;
            case 'i': show_ifaces = 1; break;
            case 'p': /* PID tracking not supported */ break;
            case 's': /* statistics not supported */ break;
            case 'h': print_help(argv[0]); return 0;
            default: print_help(argv[0]); return 1;
        }
    }

    /* Default: show all TCP */
    if (!show_tcp_flag && !show_udp_flag && !show_route_flag && !show_ifaces) {
        show_tcp_flag = 1;
    }

    if (show_route_flag) show_route();
    if (show_ifaces) show_interfaces();
    if (show_tcp_flag) show_tcp(listening, numeric);
    if (show_udp_flag) show_udp(numeric);

    return 0;
}
